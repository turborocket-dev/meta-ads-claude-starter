# =============================================================================
# ⚠️  AVISO DE SEGURANÇA: cada aluno DEVE ter seu PRÓPRIO Meta App
# =============================================================================
# NÃO compartilhe o mesmo APP_ID/APP_SECRET entre múltiplos alunos.
# Caso real (nov/2025): agência foi banida porque vários usuários compartilhavam
# o app de um vendor — quando 1 token vazou, Meta baniu TODOS simultaneamente.
# Cada pessoa: cria SEU próprio app em developers.facebook.com.
# =============================================================================

# =============================================================================
# OBRIGATÓRIO pra uso básico (Claude Code com 60 pts/h)
# =============================================================================

# System User token (gera em business.facebook.com → Configurações
# → Usuários → Usuários do Sistema → Gerar Novo Token)
# Permissions: ads_management, ads_read, business_management
# Expiração: Never
META_ACCESS_TOKEN=YOUR_SYSTEM_USER_TOKEN_HERE

# App Secret (developers.facebook.com → seu app → Settings → Basic
# → App Secret → "Show")
# IMPORTANTE: sem espaço/quebra de linha no final
META_APP_SECRET=YOUR_APP_SECRET_HERE

# Nome da sua empresa (aparece no dashboard se você fizer App Review)
ORG_NAME=Your Business Name


# =============================================================================
# OPCIONAL — só preenche se for fazer Meta App Review (Standard Access)
# =============================================================================
# Se você só quer usar Claude Code com 60 pts/h, ignora as próximas variáveis.
# Quando você decidir evoluir pra Standard Access (9.000 pts/h), o Claude
# vai te pedir esses valores e adicionar aqui automaticamente.

# Business Manager ID (numérico)
# Get: business.facebook.com → Configurações → Info do Negócio
# META_BM_ID=1234567890

# Ad accounts pra mostrar no dashboard demo (JSON array)
# Get: business.facebook.com → Configurações → Contas de Anúncios
# META_AD_ACCOUNTS=[{"id":"act_xxxxxxxxx","name":"Main Account","label":"Main"}]
